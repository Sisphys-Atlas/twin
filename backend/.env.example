# ── Required for production ────────────────────────────────────────────────────

# Set ENVIRONMENT=production to enable strict security checks
ENVIRONMENT=production

# Random 64-char string — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME

# Shared secret between bridge and backend — any long random string
BRIDGE_SECRET=CHANGE_ME

# Your frontend URL (no trailing slash)
ALLOWED_ORIGIN=https://yourdomain.com

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/twin

# Google Gemini API key
GEMINI_API_KEY=your-gemini-key
